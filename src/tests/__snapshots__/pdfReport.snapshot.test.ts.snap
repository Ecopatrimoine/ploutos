  .hypo-title{font-size:11pt;font-weight:700;color:#0F172A;margin-bottom:3px;}
  .hypo-notes{font-size:8pt;color:#555;font-style:italic;background:rgba(227,175,100,0.1);padding:5px 9px;border-radius:4px;margin-bottom:9px;border-left:3px solid #C4973D;}
