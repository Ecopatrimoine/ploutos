      <div style="text-align:right;font-size:7.5pt;color:#888;margin-top:4px;">ORIAS n° <strong style="color:#666">25006907</strong><br/>25 mai 2026</div>
    </div>
    <!-- Corps cover -->
    <div class="cover-body">
      <div style="display:inline-block;background:#0F172A;color:#C4973D;font-size:8pt;font-weight:700;text-transform:uppercase;letter-spacing:2px;padding:5px 16px;border-radius:20px;margin-bottom:22px;">Rapport patrimonial</div>
      <div class="cover-client">Pierre Dupont</div>
      <div style="font-size:13pt;color:#26428B;font-weight:600;margin-top:-4px;margin-bottom:10px;">&amp; Sophie Dupont</div>
      <div class="cover-date">25 mai 2026</div>
