  .kpi-grid-2{grid-template-columns:repeat(2,1fr);}
  .kpi{background:linear-gradient(160deg,#FDF6E8 0%,#fff8f0 100%);border:0.5px solid rgba(227,175,100,0.3);border-radius:10px;padding:9px 11px;box-shadow:0 1px 2px rgba(0,0,0,0.03);}
