      </div></div>
    </div>
  </div>
  <div class="section"><div class="section-title">Immobilier</div><table><thead><tr><th>Bien</th><th>Type</th><th>Valeur brute</th><th>Cap. restant</th><th>Loyer/an</th></tr></thead><tbody><tr class="row-even"><td>Résidence principale</td><td>Résidence principale</td><td>650 000 €</td><td>380 000 €</td><td>—</td></tr><tr class="row-odd"><td>Locatif Toulouse</td><td>Location nue</td><td>280 000 €</td><td>—</td><td>13 200 €</td></tr></tbody></table></div>
  <div class="section"><div class="section-title">Placements</div><table><thead><tr><th>Placement</th><th>Type</th><th>Propriétaire</th><th>Valeur</th></tr></thead><tbody><tr class="row-even"><td>AV Mon Contrat</td><td>Assurance-vie unités de compte</td><td>Commun</td><td>120 000 €</td></tr><tr class="row-odd"><td>PER Pierre</td><td>PER assurantiel</td><td>Pierre Dupont</td><td>45 000 €</td></tr><tr class="row-even"><td>Livret A</td><td>Livret A</td><td>Commun</td><td>22 950 €</td></tr></tbody></table></div>
