  .demarche-block{border:1px solid rgba(227,175,100,0.22);border-radius:10px;padding:16px;background:linear-gradient(135deg,#0F172A06 0%,#C4973D0a 100%);}
  .demarche-step{display:flex;align-items:flex-start;gap:11px;margin-bottom:12px;}
